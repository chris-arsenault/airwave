<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/device_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:text="Airwave"
        android:textColor="@color/widget_accent"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/now_title"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:text="Nothing playing"
        android:textColor="@color/widget_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/now_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Tap device name to cycle"
        android:textColor="@color/widget_text_secondary"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/volume_down"
            style="@style/WidgetButton"
            android:contentDescription="Volume down"
            android:src="@drawable/ic_volume_down" />

        <ImageView
            android:id="@+id/play_pause"
            style="@style/WidgetPrimaryButton"
            android:layout_marginStart="8dp"
            android:contentDescription="Play or pause"
            android:src="@drawable/ic_play" />

        <ImageView
            android:id="@+id/next"
            style="@style/WidgetButton"
            android:layout_marginStart="8dp"
            android:contentDescription="Next track"
            android:src="@drawable/ic_skip_next" />

        <ImageView
            android:id="@+id/volume_up"
            style="@style/WidgetButton"
            android:layout_marginStart="8dp"
            android:contentDescription="Volume up"
            android:src="@drawable/ic_volume_up" />
    </LinearLayout>
</LinearLayout>
