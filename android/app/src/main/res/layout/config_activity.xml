<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Airwave Control"
        android:textColor="@color/widget_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Enter the Airwave server URL. Use the LAN address or public hostname of your Airwave server."
        android:textColor="@color/widget_text_secondary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/server_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="https://airwave.example.com"
        android:inputType="textUri"
        android:singleLine="true"
        android:textColor="@color/widget_text"
        android:textColorHint="@color/widget_text_secondary" />

    <EditText
        android:id="@+id/api_token"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Optional API token for public access"
        android:inputType="textPassword"
        android:singleLine="true"
        android:textColor="@color/widget_text"
        android:textColorHint="@color/widget_text_secondary" />

    <Button
        android:id="@+id/save_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Save and refresh widget" />

    <TextView
        android:id="@+id/config_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp" />
</LinearLayout>
